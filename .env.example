# ===========================================
# AI или Човек? - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Port to run the server on
PORT=3000

# Node environment: development | production
NODE_ENV=development

# ===========================================
# SECURITY - HTTPS
# ===========================================

# Enable HTTPS (true/false)
USE_HTTPS=false

# Path to SSL certificate file (for HTTPS)
SSL_CERT_PATH=./cert.pem

# Path to SSL private key file (for HTTPS)
SSL_KEY_PATH=./key.pem

# ===========================================
# SECURITY - AUTHENTICATION
# ===========================================

# JWT secret for admin authentication (min 32 characters)
# IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# JWT token expiration time
JWT_EXPIRES_IN=24h

# ===========================================
# SECURITY - ACCOUNT LOCKOUT
# ===========================================

# Maximum failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOGIN_LOCKOUT_MINUTES=15

# ===========================================
# SECURITY - RATE LIMITING
# ===========================================

# Enable rate limiting
ENABLE_RATE_LIMITING=true

# Maximum requests per 15 minutes per IP
RATE_LIMIT_MAX=100

# Maximum socket connections per minute per IP
SOCKET_RATE_LIMIT_MAX=50

# ===========================================
# DATA RETENTION
# ===========================================

# Days to keep old game results (0 = keep forever)
DATA_RETENTION_DAYS=30

# ===========================================
# ALLOWED ORIGINS (for CORS)
# ===========================================

# Comma-separated list of allowed origins
# Example: https://example.com,https://www.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ===========================================
# LOGGING
# ===========================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Log to file in production
LOG_TO_FILE=true

# ===========================================
# DATABASE
# ===========================================

# SQLite database file path
DB_FILE=./game_data.db

# ===========================================
# GAME SETTINGS
# ===========================================

# Time per question in seconds
QUESTION_TIME_SECONDS=15

# Number of questions per game
QUESTIONS_PER_GAME=20

# ===========================================
# BACKUP SETTINGS
# ===========================================

# Enable automatic backups
AUTO_BACKUP_ENABLED=false

# Backup directory
BACKUP_DIR=./backups

# Backup interval in hours
AUTO_BACKUP_INTERVAL_HOURS=24

# ===========================================
# METRICS & MONITORING
# ===========================================

# Enable Prometheus metrics endpoint
ENABLE_METRICS=true

# Health check secret (optional, for external monitoring)
# HEALTH_CHECK_SECRET=your-health-check-secret
